# ─────────────────────────────────────────────────────────────────────────────
# .env – Congress Stock Tracker configuration
# Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (required for notifications) ────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy the token below
TELEGRAM_BOT_TOKEN=

# 2. Send any message to your new bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Look for "chat":{"id": XXXXXXX} → paste that number below
TELEGRAM_CHAT_ID=

# ── Quiver Quantitative (optional backup data source) ────────────────────────
# Free API key at https://www.quiverquant.com/  (sign up, no credit card)
QUIVER_API_KEY=

# ── App settings (optional – defaults shown) ─────────────────────────────────
POLL_INTERVAL_MINUTES=15
PORT=8000
DATABASE_PATH=trades.db

# ── Local testing without real API calls ─────────────────────────────────────
# Set to "true" to populate the dashboard with synthetic trades immediately
MOCK_DATA=false
